[
  {
    "id": "TC001",
    "title": "Login succeeds with valid credentials and Remember Me checked",
    "description": "Verifies a user can sign in with valid email/password, optionally enabling Remember Me, and sees a success confirmation.",
    "category": "User Login",
    "priority": "High",
    "steps": [
      {
        "type": "action",
        "description": "Navigate to /login"
      },
      {
        "type": "assertion",
        "description": "Verify text \"Login\" is visible"
      },
      {
        "type": "action",
        "description": "Type \"{{LOGIN_USER}}\" into the email field"
      },
      {
        "type": "action",
        "description": "Type \"{{LOGIN_PASSWORD}}\" into the password field"
      },
      {
        "type": "action",
        "description": "Click on the \"Remember me\" checkbox"
      },
      {
        "type": "action",
        "description": "Click on the \"Login\" button"
      },
      {
        "type": "assertion",
        "description": "Verify text \"successful\" is visible"
      }
    ]
  },
