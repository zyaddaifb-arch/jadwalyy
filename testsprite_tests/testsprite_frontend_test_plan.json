  {
    "id": "TC016",
    "title": "Successful student booking submission shows confirmation",
    "description": "Verifies a student can submit the booking form with valid inputs and sees a confirmation message.",
    "category": "Student Booking",
    "priority": "High",
    "steps": [
      {
        "type": "action",
        "description": "Navigate to /test-teacher/test-group/book"
      },
      {
        "type": "assertion",
        "description": "Verify text \"Booking\" is visible"
      },
      {
        "type": "action",
        "description": "Type \"Test Student A\" into the student name input field"
      },
      {
        "type": "action",
        "description": "Type \"Test School\" into the school input field"
      },
      {
        "type": "action",
        "description": "Type \"5551234567\" into the student phone input field"
      },
      {
        "type": "action",
        "description": "Type \"5559876543\" into the parent phone input field"
      },
      {
        "type": "action",
        "description": "Click the Submit booking button"
      },
      {
        "type": "assertion",
        "description": "Verify text \"confirmation\" is visible"
      }
    ]
  },
